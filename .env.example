# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# .env is git-ignored — NEVER commit .env
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME="Mil API"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key

# Mobile app shared secret — all requests must include X-App-Key: <value>
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_API_KEY=replace-with-a-random-hex-key

# JWT expiry
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (DigitalOcean Managed Postgres)
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=25060
DB_NAME=defaultdb
DB_SSLMODE=require

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_SMS=+1xxxxxxxxxx
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886

# Apple Sign In
APPLE_APP_BUNDLE_ID=com.yourcompany.yourapp

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenAI
OPENAI_API_KEY=sk-...

# Facebook Sign In
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# OTP policy
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_BLOCK_MINUTES=30
OTP_MAX_SENDS_PER_HOUR=3

# DigitalOcean Spaces (S3-compatible storage)
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=your_bucket_name
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_CDN_BASE=https://your_bucket.sfo3.cdn.digitaloceanspaces.com

# RevenueCat
REVENUECAT_PUBLIC_KEY=appl_...
REVENUECAT_SECRET_KEY=sk_...
REVENUECAT_WEBHOOK_AUTH=your_webhook_auth_header

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# AWS Rekognition (face detection + matching — used by Tinder, Bumble, Hinge)
# Create an IAM user with AmazonRekognitionReadOnlyAccess policy in us-east-1
# https://console.aws.amazon.com/iam/home#/users
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
